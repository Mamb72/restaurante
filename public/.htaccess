# Habilita el motor de reescritura
RewriteEngine On

# Si la URL apunta a un archivo o carpeta real existentes,
# los sirve directamente sin pasar por el router.
# Esto permite acceder a /assets/css/cliente.css, imágenes, etc.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Todo lo demás se redirige a index.php
RewriteRule ^ index.php [QSA,L]
